{
    "title": "YouTube API Hashtag Search",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "hashtag": {
            "title": "Hashtag",
            "type": "string",
            "description": "Hashtag to search for (without #)",
            "editor": "textfield"
        },
        "sort": {
            "title": "sort",
            "type": "string",
            "description": "Sort by: relevance, rating, upload_date, view_count",
            "editor": "select",
            "items": {
                "type": "string",
                "enum": [
                    "relevance",
                    "rating",
                    "upload_date",
                    "view_count"
                ]
            },
            "prefill": "relevance"
        },
        "duration": {
            "title": "duration",
            "type": "string",
            "description": "Video duration: short, medium, long",
            "editor": "select",
            "items": {
                "type": "string",
                "enum": [
                    "short",
                    "medium",
                    "long"
                ]
            },
            "prefill": "short"
        },
        "upload_date": {
            "title": "upload date",
            "type": "string",
            "description": "Upload date",
            "editor": "select",
            "items": {
                "type": "string",
                "enum": [
                    "hour",
                    "today",
                    "week",
                    "month",
                    "year"
                ]
            },
            "prefill": "hour"
        },
        "limit": {
            "title": "limit",
            "type": "integer",
            "description": "Results per page (1-50, default: 20)",
            "default": 20,
            "minimum": 1,
            "maximum": 1024
        },
        "continuation": {
            "title": "Continuation token",
            "type": "string",
            "description": "Pagination token for next page",
            "editor": "textfield"
        },
        "contentType": {
            "title": "content type",
            "type": "string",
            "description": "Filter by content type",
            "editor": "select",
            "items": {
                "type": "string",
                "enum": [
                    "live",
                    "recorded",
                    "premiere"
                ]
            },
            "prefill": "live"
        },
        "features": {
            "title": "features",
            "type": "string",
            "description": "Comma-separated: live,4k,hd,subtitles,cc,360,vr180,3d,hdr",
            "editor": "textfield"
        }
    },
    "required": [
        "hashtag"
    ]
}
