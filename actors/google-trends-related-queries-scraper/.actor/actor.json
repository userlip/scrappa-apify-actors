{
  "actorSpecification": 1,
  "name": "google-trends-related-queries-scraper",
  "title": "Google Trends Related Queries Scraper",
  "description": "Find Google Trends related queries and topics for SEO keyword research, content planning, and market monitoring. Extract top and rising query/topic rows from Scrappa's Google Trends Related Queries API.",
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "ts-start"
  },
  "input": "./input_schema.json",
  "dockerfile": "../Dockerfile",
  "environmentVariables": {
    "SCRAPPA_API_KEY": "@SCRAPPA_API_KEY"
  },
  "resources": {
    "memoryMbytes": 128
  },
  "defaultRunOptions": {
    "timeoutSecs": 420
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "related_queries": {
          "title": "Related Queries",
          "transformation": {
            "fields": ["position", "result_kind", "type", "query", "topic", "topic_type", "value", "formatted_value", "link", "source_keyword", "request_geo", "request_time_range", "request_hl", "request_search_type", "response_time_ms"]
          },
          "display": {
            "component": "table",
            "properties": {
              "position": { "label": "#", "format": "number" },
              "result_kind": { "label": "Kind", "format": "text" },
              "type": { "label": "Type", "format": "text" },
              "query": { "label": "Query", "format": "text" },
              "topic": { "label": "Topic", "format": "text" },
              "topic_type": { "label": "Topic Type", "format": "text" },
              "value": { "label": "Value", "format": "number" },
              "formatted_value": { "label": "Formatted Value", "format": "text" },
              "link": { "label": "Link", "format": "link" },
              "source_keyword": { "label": "Source Keyword", "format": "text" },
              "request_geo": { "label": "Location", "format": "text" },
              "request_time_range": { "label": "Time Range", "format": "text" },
              "request_hl": { "label": "Language", "format": "text" },
              "request_search_type": { "label": "Search Type", "format": "text" },
              "response_time_ms": { "label": "Response Time", "format": "number" }
            }
          }
        }
      }
    }
  }
}
