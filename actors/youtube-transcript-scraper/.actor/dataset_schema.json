{
    "actorSpecification": 1,
    "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
            "videoId": {
                "type": ["string", "null"],
                "title": "Video ID",
                "description": "The YouTube video ID.",
                "example": "dQw4w9WgXcQ"
            },
            "language": {
                "type": ["string", "null"],
                "title": "Language",
                "description": "Returned transcript language code."
            },
            "languageName": {
                "type": ["string", "null"],
                "title": "Language Name",
                "description": "Returned transcript language name."
            },
            "sourceLanguage": {
                "type": ["string", "null"],
                "title": "Source Language",
                "description": "Original transcript language code when translated."
            },
            "sourceLanguageName": {
                "type": ["string", "null"],
                "title": "Source Language Name",
                "description": "Original transcript language name when translated."
            },
            "isAutoGenerated": {
                "type": ["boolean", "null"],
                "title": "Auto Generated",
                "description": "Whether the transcript was auto-generated."
            },
            "isTranslated": {
                "type": ["boolean", "null"],
                "title": "Translated",
                "description": "Whether the transcript was translated."
            },
            "segmentCount": {
                "type": ["integer", "null"],
                "title": "Segment Count",
                "description": "Number of transcript segments."
            },
            "text": {
                "type": ["string", "null"],
                "title": "Full Text",
                "description": "Complete transcript text returned by Scrappa."
            },
            "transcript": {
                "type": ["array", "null"],
                "title": "Transcript",
                "description": "Timed transcript segments."
            },
            "availableLanguages": {
                "type": ["array", "null"],
                "title": "Available Languages",
                "description": "Transcript languages YouTube exposes for the video."
            },
            "translationLanguages": {
                "type": ["array", "null"],
                "title": "Translation Languages",
                "description": "Translation languages available for this transcript."
            }
        }
    },
    "views": {
        "overview": {
            "title": "YouTube Transcript",
            "transformation": {
                "fields": [
                    "videoId",
                    "text",
                    "language",
                    "languageName",
                    "sourceLanguage",
                    "sourceLanguageName",
                    "segmentCount",
                    "isAutoGenerated",
                    "isTranslated"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "videoId": {
                        "label": "Video ID",
                        "format": "text"
                    },
                    "text": {
                        "label": "Full Text",
                        "format": "text"
                    },
                    "language": {
                        "label": "Language",
                        "format": "text"
                    },
                    "languageName": {
                        "label": "Language Name",
                        "format": "text"
                    },
                    "sourceLanguage": {
                        "label": "Source",
                        "format": "text"
                    },
                    "sourceLanguageName": {
                        "label": "Source Name",
                        "format": "text"
                    },
                    "segmentCount": {
                        "label": "Segments",
                        "format": "number"
                    },
                    "isAutoGenerated": {
                        "label": "Auto",
                        "format": "boolean"
                    },
                    "isTranslated": {
                        "label": "Translated",
                        "format": "boolean"
                    }
                }
            }
        }
    }
