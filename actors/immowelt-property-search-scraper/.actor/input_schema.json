{
  "title": "Immowelt Property Search Scraper",
  "description": "Search Immowelt property listings by location and property type. Each returned listing is saved as one dataset item.",
  "type": "object",
  "schemaVersion": 1,
  "required": ["location"],
  "properties": {
    "location": {
      "title": "Location",
      "type": "string",
      "description": "City, district, postal code, or location query to search on Immowelt.",
      "editor": "textfield",
      "prefill": "Berlin",
      "default": "Berlin",
      "maxLength": 120
    },
    "type": {
      "title": "Search Type",
      "type": "string",
      "description": "Scrappa Immowelt search type.",
      "editor": "select",
      "enum": ["apartment-rent", "apartment-buy", "house-rent", "house-buy"],
      "enumTitles": ["Apartment rent", "Apartment buy", "House rent", "House buy"],
      "default": "apartment-rent"
    },
    "page": {
      "title": "Page",
      "type": "integer",
      "description": "Results page to fetch.",
      "editor": "number",
      "minimum": 1,
      "maximum": 10000,
      "default": 1
    },
    "per_page": {
      "title": "Results per page",
      "type": "integer",
      "description": "Number of listings to request for this page.",
      "editor": "number",
      "minimum": 1,
      "maximum": 50,
      "default": 20
    }
  }
}
