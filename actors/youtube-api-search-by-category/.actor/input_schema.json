{
  "title": "Search YouTube by category",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "category": {
      "title": "Category",
      "type": "array",
      "description": "Category to search in",
      "editor": "select",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "education",
          "music",
          "gaming",
          "news",
          "sports",
          "entertainment",
          "howto",
          "tech",
          "science",
          "travel",
          "food",
          "lifestyle",
          "fitness",
          "beauty",
          "fashion",
          "diy",
          "pets",
          "cars",
          "movies",
          "books"
        ]
      },
      "prefill": ["education"]
    },
    "sort": {
      "title": "Sort",
      "type": "array",
      "description": "Sort by: relevance, rating, upload_date, view_count",
      "editor": "select",
      "maxItems": 1,
      "items": {
        "type": "string",
        "enum": ["relevance", "rating", "upload_date", "view_count"]
      },
      "prefill": ["relevance"]
    },
    "duration": {
      "title": "Duration",
      "type": "array",
      "description": "Video duration: short, medium, long",
      "editor": "select",
      "maxItems": 1,
      "items": {
        "type": "string",
        "enum": ["short", "medium", "long"]
      },
      "prefill": ["short"]
    },
    "upload_date": {
      "title": "Upload date",
      "type": "array",
      "description": "Upload date filter",
      "editor": "select",
      "maxItems": 1,
      "items": {
        "type": "string",
        "enum": ["hour", "today", "week", "month", "year"]
      },
      "prefill": ["hour"]
    },
    "limit": {
      "title": "Limit",
      "type": "integer",
      "description": "Maximum number of results to return",
      "default": 10,
      "minimum": 1,
      "maximum": 20
    },
    "continuation": {
      "title": "Continuation",
      "type": "string",
      "description": "Pagination token for next page",
      "editor": "textfield"
    },
    "contentType": {
      "title": "Content type",
      "type": "array",
      "description": "Filter by content type",
      "editor": "select",
      "maxItems": 1,
      "items": {
        "type": "string",
        "enum": ["live", "recorded", "premiere"]
      }
    },
    "features": {
      "title": "Features",
      "type": "string",
      "description": "Comma-separated: live,4k,hd,subtitles,cc,360,vr180,3d,hdr",
      "editor": "textfield"
    }
  },
  "required": ["category"]
}
