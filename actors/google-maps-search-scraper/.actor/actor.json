{
  "actorSpecification": 1,
  "name": "google-maps-search-scraper",
  "title": "Google Maps Search",
  "description": "Discover Google Maps businesses by query and location. Extract names, ratings, reviews, addresses, phone numbers, websites, categories, photos, hours, and business IDs for lead generation.",
  "version": "1.0",
  "buildTag": "latest",
  "icon": "🔍",
  "meta": { "templateId": "ts-start" },
  "input": "./input_schema.json",
  "dockerfile": "./Dockerfile",
  "environmentVariables": { "SCRAPPA_API_KEY": "@SCRAPPA_API_KEY" },
  "resources": {
    "memoryMbytes": 256
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "overview": {
          "title": "Search Results",
          "transformation": {
            "fields": [
              "name",
              "type",
              "rating",
              "review_count",
              "full_address",
              "latitude",
              "longitude",
              "phone_numbers",
              "website",
              "business_id",
              "place_id",
              "timezone"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "name": { "label": "Name", "format": "text" },
              "type": { "label": "Type", "format": "text" },
              "rating": { "label": "Rating", "format": "number" },
              "review_count": { "label": "Reviews", "format": "number" },
              "full_address": { "label": "Address", "format": "text" },
              "latitude": { "label": "Latitude", "format": "number" },
              "longitude": { "label": "Longitude", "format": "number" },
              "phone_numbers": { "label": "Phone numbers", "format": "array" },
              "website": { "label": "Website", "format": "link" },
              "business_id": { "label": "Business ID", "format": "text" },
              "place_id": { "label": "Place ID", "format": "text" },
              "timezone": { "label": "Timezone", "format": "text" }
            }
          }
        }
      }
    }
  }
}
