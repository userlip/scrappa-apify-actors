{
  "actorSpecification": 1,
  "name": "google-trends-autocomplete-scraper",
  "title": "Google Trends Autocomplete Scraper",
  "description": "Get Google Trends autocomplete suggestions for SEO keyword research, content planning, and market monitoring. Extract one dataset row per suggestion from Scrappa's Google Trends Autocomplete API.",
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "ts-start"
  },
  "input": "./input_schema.json",
  "dockerfile": "../Dockerfile",
  "environmentVariables": {
    "SCRAPPA_API_KEY": "@SCRAPPA_API_KEY"
  },
  "resources": {
    "memoryMbytes": 128
  },
  "defaultRunOptions": {
    "timeoutSecs": 180
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "suggestions": {
          "title": "Suggestions",
          "transformation": {
            "fields": ["position", "suggestion", "type", "source_keyword", "request_geo", "request_hl", "response_time_ms"]
          },
          "display": {
            "component": "table",
            "properties": {
              "position": { "label": "#", "format": "number" },
              "suggestion": { "label": "Suggestion", "format": "text" },
              "type": { "label": "Type", "format": "text" },
              "source_keyword": { "label": "Source Keyword", "format": "text" },
              "request_geo": { "label": "Location", "format": "text" },
              "request_hl": { "label": "Language", "format": "text" },
              "response_time_ms": { "label": "Response Time", "format": "number" }
            }
          }
        }
      }
    }
  }
}
