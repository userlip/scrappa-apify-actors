{
    "title": "YouTube API Video Comments",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "id": {
            "title": "YouTube Video ID",
            "type": "string",
            "description": "The YouTube video ID to fetch comments for.",
            "editor": "textfield",
            "prefill": "dQw4w9WgXcQ"
        },
        "continuation": {
            "title": "Continuation",
            "type": "string",
            "description": "Pagination token returned by the previous run to continue to the next comments page.",
            "editor": "textfield"
        },
        "sort": {
            "title": "Sort",
            "type": "array",
            "description": "Sort order for the comments feed.",
            "editor": "select",
            "items": {
                "type": "string",
                "enum": ["TOP_COMMENTS", "NEWEST_FIRST"]
            },
            "maxItems": 1,
            "prefill": ["TOP_COMMENTS"]
        }
    },
    "required": ["id"]
}
