{
  "title": "Instagram User Info",
  "description": "Fetch public Instagram profile information for one username.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "username": {
      "title": "Instagram username",
      "type": "string",
      "description": "Instagram username without the @ symbol.",
      "editor": "textfield",
      "prefill": "natgeo",
      "pattern": "^@?[a-zA-Z0-9._-]{1,30}$"
    }
  },
  "required": ["username"]
}
