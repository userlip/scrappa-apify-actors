{
  "actorSpecification": 1,
  "name": "indeed-jobs-scraper",
  "title": "Indeed Jobs Scraper ($0.30/1k results)",
  "description": "Search Indeed job listings with Scrappa. Extract job titles, companies, locations, salaries, descriptions, attributes, apply URLs, and pagination cursors.",
  "categories": [
    "LEAD_GENERATION",
    "MARKETING",
    "AUTOMATION"
  ],
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "ts-start"
  },
  "input": "./input_schema.json",
  "dockerfile": "./Dockerfile",
  "environmentVariables": {
    "SCRAPPA_API_KEY": "@SCRAPPA_API_KEY"
  },
  "resources": {
    "memoryMbytes": 256
  },
  "defaultRunOptions": {
    "timeoutSecs": 300
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "jobs": {
          "title": "Indeed Jobs",
          "transformation": {
            "fields": ["title", "company_name", "location_formatted", "salary", "attributes", "date_published", "apply_url"]
          },
          "display": {
            "component": "table",
            "properties": {
              "title": { "label": "Title", "format": "text" },
              "company_name": { "label": "Company", "format": "text" },
              "location_formatted": { "label": "Location", "format": "text" },
              "salary": { "label": "Salary", "format": "object" },
              "attributes": { "label": "Attributes", "format": "array" },
              "date_published": { "label": "Date Published", "format": "text" },
              "apply_url": { "label": "Apply URL", "format": "link" }
            }
          }
        }
      }
    }
  }
}
