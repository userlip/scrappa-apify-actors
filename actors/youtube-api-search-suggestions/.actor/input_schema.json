{
  "title": "YouTube Search Suggestions",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "q": {
      "title": "Query",
      "type": "string",
      "description": "Search query to get YouTube autocomplete suggestions for.",
      "editor": "textfield",
      "prefill": "javascript"
    },
    "hl": {
      "title": "Language",
      "type": "string",
      "description": "YouTube interface language code.",
      "editor": "textfield",
      "prefill": "en"
    },
    "gl": {
      "title": "Country",
      "type": "string",
      "description": "Two-letter country code used for localized suggestions.",
      "editor": "textfield",
      "prefill": "US"
    }
  },
  "required": ["q"]
}
