{
  "actorSpecification": 1,
  "name": "google-patents-details-scraper",
  "title": "Google Patents Details Scraper",
  "description": "Enrich Google Patents publication IDs and URLs with full patent metadata, abstracts, inventors, assignees, dates, citations, and links.",
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "ts-start"
  },
  "input": "./input_schema.json",
  "dockerfile": "./Dockerfile",
  "environmentVariables": {
    "SCRAPPA_API_KEY": "@SCRAPPA_API_KEY"
  },
  "resources": {
    "memoryMbytes": 128
  },
  "defaultRunOptions": {
    "timeoutSecs": 120
  },
  "categories": [
    "BUSINESS",
    "DEVELOPER_TOOLS",
    "AUTOMATION"
  ],
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "patents": {
          "title": "Patent Details",
          "transformation": {
            "fields": [
              "success",
              "input_patent_id",
              "normalized_patent_id",
              "patent_id",
              "publication_number",
              "patent_page",
              "title",
              "abstract",
              "inventors",
              "assignees",
              "dates",
              "country",
              "language",
              "application_number",
              "prior_art_keywords",
              "links",
              "citations",
              "inventor_count",
              "assignee_count",
              "citation_count",
              "cached",
              "response_time_ms",
              "error",
              "status_code"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "success": { "label": "Success", "format": "boolean" },
              "input_patent_id": { "label": "Input", "format": "text" },
              "normalized_patent_id": { "label": "Normalized ID", "format": "text" },
              "patent_id": { "label": "Patent ID", "format": "text" },
              "publication_number": { "label": "Publication #", "format": "text" },
              "patent_page": { "label": "Patent Page", "format": "link" },
              "title": { "label": "Title", "format": "text" },
              "abstract": { "label": "Abstract", "format": "text" },
              "country": { "label": "Country", "format": "text" },
              "language": { "label": "Language", "format": "text" },
              "application_number": { "label": "Application #", "format": "text" },
              "inventor_count": { "label": "Inventors", "format": "number" },
              "assignee_count": { "label": "Assignees", "format": "number" },
              "citation_count": { "label": "Citations", "format": "number" },
              "cached": { "label": "Cached", "format": "boolean" },
              "response_time_ms": { "label": "Response Time", "format": "number" },
              "error": { "label": "Error", "format": "text" },
              "status_code": { "label": "Status", "format": "number" }
            }
          }
        }
      }
    }
  }
}
