{
  "title": "ImmobilienScout24 Search Scraper",
  "description": "Search ImmobilienScout24 property listings by location, property type, price, rooms, and size. Each returned listing is saved as one dataset item.",
  "type": "object",
  "schemaVersion": 1,
  "required": ["location"],
  "properties": {
    "location": {
      "title": "Location",
      "type": "string",
      "description": "City name, district, postal code, or ImmobilienScout24 geocode.",
      "editor": "textfield",
      "prefill": "1276003001",
      "default": "1276003001",
      "maxLength": 120
    },
    "type": {
      "title": "Search Type",
      "type": "string",
      "description": "Scrappa ImmobilienScout24 search type.",
      "editor": "select",
      "enum": ["apartment-rent", "apartment-buy", "house-rent", "house-buy"],
      "enumTitles": ["Apartment rent", "Apartment buy", "House rent", "House buy"],
      "default": "apartment-rent"
    },
    "price_min": {
      "title": "Minimum price",
      "type": "integer",
      "description": "Minimum price in EUR.",
      "editor": "number",
      "minimum": 0
    },
    "price_max": {
      "title": "Maximum price",
      "type": "integer",
      "description": "Maximum price in EUR.",
      "editor": "number",
      "minimum": 0
    },
    "rooms_min": {
      "title": "Minimum rooms",
      "type": "number",
      "description": "Minimum number of rooms, for example 1.5.",
      "editor": "number",
      "minimum": 0
    },
    "rooms_max": {
      "title": "Maximum rooms",
      "type": "number",
      "description": "Maximum number of rooms.",
      "editor": "number",
      "minimum": 0
    },
    "size_min": {
      "title": "Minimum size",
      "type": "integer",
      "description": "Minimum floor area in square meters.",
      "editor": "number",
      "minimum": 0
    },
    "size_max": {
      "title": "Maximum size",
      "type": "integer",
      "description": "Maximum floor area in square meters.",
      "editor": "number",
      "minimum": 0
    },
    "page": {
      "title": "Page",
      "type": "integer",
      "description": "Results page to fetch.",
      "editor": "number",
      "minimum": 1,
      "maximum": 10000,
      "default": 1
    },
    "per_page": {
      "title": "Results per page",
      "type": "integer",
      "description": "Number of listings to request for this page.",
      "editor": "number",
      "minimum": 1,
      "maximum": 50,
      "default": 20
    }
  }
}
