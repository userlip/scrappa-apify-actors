{
    "title": "YouTube API Channel Livestreams",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "id": {
            "title": "Legacy YouTube Channel ID",
            "type": "string",
            "description": "Single YouTube channel ID. Use ids for batch runs.",
            "editor": "textfield",
            "prefill": "UCJZv4d5rbIKd4QHMPkcABCw"
        },
        "ids": {
            "title": "YouTube Channel IDs",
            "type": "string",
            "description": "Comma-separated YouTube channel IDs. Prefer this for batch runs.",
            "editor": "textfield",
            "pattern": "^\\s*[^,\\s]+(?:\\s*,\\s*[^,\\s]+)*\\s*$",
            "prefill": "UCJZv4d5rbIKd4QHMPkcABCw,UC_x5XG1OV2P6uZZ5FSM9Ttw"
        },
        "continuation": {
            "title": "Continuation token",
            "type": "string",
            "description": "Pagination token for next page",
            "editor": "textfield"
        },
        "sort": {
            "title": "sort",
            "type": "string",
            "description": "Sort by (newest, popular, oldest)",
            "editor": "select",
            "items": {
                "type": "string",
                "enum": [
                    "newest",
                    "popular",
                    "oldest"
                ]
            },
            "prefill": "newest"
        }
    },
    "required": []
}
