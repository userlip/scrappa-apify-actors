{
  "title": "Search for a specific playlists",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "q": {
      "title": "Search playlists",
      "type": "string",
      "description": "Search query for playlists",
      "editor": "textfield"
    },
    "sort": {
      "title": "sort",
      "type": "array",
      "description": "Sort by: relevance, rating, upload_date, view_count",
      "editor": "select",
      "items": {
        "type": "string",
        "enum": ["relevance", "rating", "upload_date","view_count"]
      },
      "prefill": ["relevance"]
    },
    "limit": {
      "title": "limit",
      "type": "integer",
      "description": "Results per page (1-50, default: 20)",
      "default": 1,
      "minimum": 1,
      "maximum": 1024
    },
     "continuation": {
      "title": "continuation",
      "type": "string",
      "description": "Pagination token for next page",
      "editor": "textfield"
    }
  },
  "required": ["q"]
}