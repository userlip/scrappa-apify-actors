{
  "actorSpecification": 1,
  "name": "tiktok-ads-scraper",
  "title": "TikTok Ads Scraper",
  "description": "Extract TikTok Creative Center ad details, advertiser fields, creative text, media URLs, landing pages, metadata, and engagement metrics through Scrappa.",
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "ts-start"
  },
  "input": "./input_schema.json",
  "dockerfile": "./Dockerfile",
  "environmentVariables": {
    "SCRAPPA_API_KEY": "@SCRAPPA_API_KEY"
  },
  "resources": {
    "memoryMbytes": 128
  },
  "defaultRunOptions": {
    "timeoutSecs": 300
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "ads": {
          "title": "Ads",
          "transformation": {
            "fields": ["ad_id", "advertiser_name", "brand_name", "advertiser_id", "account_name", "industry", "objective", "creative_text", "landing_page", "destination", "cta", "video_url", "cover", "media_urls", "region", "country", "language", "category", "like_count", "comment_count", "share_count", "cached", "request_url", "request_ad_id", "request_index", "result_found", "error_message"]
          },
          "display": {
            "component": "table",
            "properties": {
              "ad_id": { "label": "Ad ID", "format": "text" },
              "advertiser_name": { "label": "Advertiser", "format": "text" },
              "brand_name": { "label": "Brand", "format": "text" },
              "advertiser_id": { "label": "Advertiser ID", "format": "text" },
              "account_name": { "label": "Account", "format": "text" },
              "industry": { "label": "Industry", "format": "text" },
              "objective": { "label": "Objective", "format": "text" },
              "creative_text": { "label": "Creative Text", "format": "text" },
              "landing_page": { "label": "Landing Page", "format": "link" },
              "destination": { "label": "Destination", "format": "link" },
              "cta": { "label": "CTA", "format": "text" },
              "video_url": { "label": "Video URL", "format": "link" },
              "cover": { "label": "Cover", "format": "link" },
              "media_urls": { "label": "Media URLs", "format": "array" },
              "region": { "label": "Region", "format": "text" },
              "country": { "label": "Country", "format": "text" },
              "language": { "label": "Language", "format": "text" },
              "category": { "label": "Category", "format": "text" },
              "like_count": { "label": "Likes", "format": "number" },
              "comment_count": { "label": "Comments", "format": "number" },
              "share_count": { "label": "Shares", "format": "number" },
              "cached": { "label": "Cached", "format": "boolean" },
              "request_url": { "label": "Request URL", "format": "link" },
              "request_ad_id": { "label": "Request Ad ID", "format": "text" },
              "request_index": { "label": "Request #", "format": "number" },
              "result_found": { "label": "Found", "format": "boolean" },
              "error_message": { "label": "Error", "format": "text" }
            }
          }
        }
      }
    }
  }
}
